<plugin
        id="com.cosmic.vpplugin.v2"
        name="Cosmic AI V2"
        description="Plugin per l'integrazione di LLM..."
        provider="Alberto"
        class="com.cosmic.vpplugin.CosmicPlugin">

    <actionSets>
        <!-- 1) Azione per la Ribbon / Sleek UI Nativa (Tab: Plug-ins -> Gruppo: Cosmic AI) -->
        <actionSet id="com.cosmic.vpplugin.actions.MainActionSet">
            <action
                    id="com.cosmic.vpplugin.actions.OpenAnalyzerPane"
                    actionType="generalAction"
                    label="COSMIC AI Analyzer"
                    tooltip="Apri il pannello COSMIC AI per l'import dei requisiti e la generazione del diagramma"
                    menuPath="Plug-ins/Cosmic AI">
                <actionController class="com.cosmic.vpplugin.action.CosmicOpenPanelActionController"/>
            </action>
        </actionSet>

        <!-- 2) Azione di fallback per il menu contestuale (diagramPopup) -->
        <actionSet id="com.cosmic.vpplugin.actions.DiagramPopupActionSet">
            <action
                    id="com.cosmic.vpplugin.actions.DiagramPopupAction"
                    actionType="diagramPopup"
                    label="Apri COSMIC AI Analyzer"
                    tooltip="Apri il pannello COSMIC AI per l'import dei requisiti e la generazione del diagramma">
                <actionController class="com.cosmic.vpplugin.action.CosmicDiagramPopupActionController"/>
            </action>
        </actionSet>
    </actionSets>

</plugin>
